{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information, points, and proficiency levels.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "name": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["student", "teacher"], "description": "User's role in the system" },
        "computerProficiency": { 
          "type": "string", 
          "enum": ["Basic", "Intermediate", "Advanced"],
          "description": "The user's current computer knowledge level" 
        },
        "totalPoints": { "type": "integer", "description": "Total points earned across all quizzes" },
        "quizzesCompleted": { "type": "integer", "description": "Number of quizzes successfully finished" },
        "computerTopicProgress": { "type": "integer", "description": "Progress in the 'Computer' learning path (0-100)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" }
      },
      "required": ["uid", "name", "email", "role", "computerProficiency", "totalPoints", "quizzesCompleted"]
    },
    "QuizHistory": {
      "title": "Quiz History",
      "description": "Records of individual quiz attempts.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User who took the quiz" },
        "topic": { "type": "string", "description": "The subject of the quiz" },
        "score": { "type": "integer", "description": "Number of correct answers" },
        "totalQuestions": { "type": "integer", "description": "Total number of questions in the quiz" },
        "difficulty": { "type": "string", "enum": ["Beginner", "Intermediate", "Advanced"] },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the quiz was taken" }
      },
      "required": ["uid", "topic", "score", "totalQuestions", "difficulty", "timestamp"]
    },
    "TeacherFeedback": {
      "title": "Teacher Feedback",
      "description": "Feedback and suggestions provided by teachers to students.",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "studentId": { "type": "string" },
        "content": { "type": "string" },
        "suggestions": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "teacherName", "studentId", "content", "suggestions", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/quizHistory/{historyId}": {
      "schema": "QuizHistory",
      "description": "History of all quizzes taken by users"
    },
    "/feedback/{feedbackId}": {
      "schema": "TeacherFeedback",
      "description": "Feedback from teachers to students"
    }
  }
}
